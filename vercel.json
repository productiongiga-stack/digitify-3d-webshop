{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30,
        "includeFiles": "public/**/*.html",
        "regions": ["fra1"]
      }
    }
  ],
  "routes": [
    {
      "src": "/uploads-signed",
      "dest": "/api/index.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(login|register|dashboard|admin|account|cart|shop|prijzen|maattabel|support|faq|contact|verzending|legal|privacy|voorwaarden|retourneren|designer)",
      "dest": "/public/$1.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/assets/(branding|products)/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|webp|svg|ico|woff2|woff|ttf|glb|map))",
      "dest": "/public/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
